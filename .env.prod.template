# =============================================================================
# BigBright ERP Backend - Production Template
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime Profile
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
# Use prod,seed ONLY for first bootstrapping, then switch back to prod.
# SPRING_PROFILES_ACTIVE=prod,seed

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://db-host:5432/erp_domain
SPRING_DATASOURCE_USERNAME=erp
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATASOURCE_POOL_MAX=30
SPRING_DATASOURCE_POOL_MIN=5

# -----------------------------------------------------------------------------
# JWT Security
# -----------------------------------------------------------------------------
# Must be >= 32 bytes (256 bits)
JWT_SECRET=b2YKFKNDK6jiJw5Xyn9yX4nKQR3fpPWBbMUoTrjIg6SMSiLVFv_BBsTpPUKvmdUU
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
# Required for AES-256-GCM encryption (32+ bytes)
ERP_SECURITY_ENCRYPTION_KEY=uFs4OAWuRLDPsS60S9JXVBCWrz0VY49exrq_MT6hX2U

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=replace-me
SMTP_PASSWORD=replace-me
ERP_MAIL_FROM=noreply@yourdomain.com
ERP_MAIL_BASE_URL=https://app.yourdomain.com

# -----------------------------------------------------------------------------
# Licensing (required when enforce=true)
# -----------------------------------------------------------------------------
ERP_LICENSE_ENFORCE=true
ERP_LICENSE_KEY=CHANGE-ME-LICENSE
ERP_LICENSE_PRODUCT_ID=31720
ERP_LICENSE_ALGORITHM=SKM15
ERP_LICENSE_CREATED=2025-12-08
ERP_LICENSE_DESCRIPTION=ERP
ERP_LICENSE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Dispatch Journal Mapping (required for dispatch postings)
# -----------------------------------------------------------------------------
ERP_DISPATCH_DEBIT_ACCOUNT_ID=3
ERP_DISPATCH_CREDIT_ACCOUNT_ID=6

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
ERP_CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
MANAGEMENT_CORS_ALLOWED_ORIGINS=https://ops.yourdomain.com

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_PORT=8081
MANAGEMENT_SERVER_PORT=9090

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
ERP_RATE_LIMIT_RPM=60
