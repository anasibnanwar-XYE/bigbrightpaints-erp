# =============================================================================
# BigBright ERP Backend Configuration
# =============================================================================
# IMPORTANT: Copy this file to .env and configure with your environment values.
# NEVER commit .env files with real credentials to version control.

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/erp_domain
SPRING_DATASOURCE_USERNAME=erp
SPRING_DATASOURCE_PASSWORD=<your-database-password>
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# Security (REQUIRED)
# -----------------------------------------------------------------------------
# JWT Secret - Must be at least 32 bytes; use a strong random value in production
# Generate with: openssl rand -base64 32
JWT_SECRET=<generate-with-openssl-rand-base64-32>

# Encryption key for sensitive data at rest (e.g., MFA secrets)
# Must be at least 32 bytes; generate with: openssl rand -base64 32
ERP_ENCRYPTION_KEY=<generate-with-openssl-rand-base64-32>

# -----------------------------------------------------------------------------
# Accounting Configuration
# -----------------------------------------------------------------------------
# Dispatch journal mapping (required to post dispatch journals)
# Set these to the correct Inventory (debit) and COGS (credit) accounts for your environment
ERP_DISPATCH_DEBIT_ACCOUNT_ID=0
ERP_DISPATCH_CREDIT_ACCOUNT_ID=0

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# For production: https://app.bigbrightpaints.com,https://admin.bigbrightpaints.com
ERP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3004

# -----------------------------------------------------------------------------
# Email Configuration (for invoice emails, payroll notifications)
# -----------------------------------------------------------------------------
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=<your-email@example.com>
SPRING_MAIL_PASSWORD=<your-app-password>
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Email sending settings
ERP_MAIL_FROM=noreply@bigbrightpaints.com
ERP_MAIL_BASE_URL=http://localhost:3002
ERP_MAIL_SEND_CREDENTIALS=true
ERP_MAIL_SEND_PASSWORD_RESET=true

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_PORT=8081

# -----------------------------------------------------------------------------
# Security Notifications (Optional, for production)
# -----------------------------------------------------------------------------
# Email recipients for security alerts (comma-separated)
ERP_SECURITY_NOTIFICATIONS_EMAIL_RECIPIENTS=security-team@bigbrightpaints.com
# Slack webhook URL for security notifications (optional)
# ERP_SECURITY_NOTIFICATIONS_SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# AI Integration (Optional)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=<your-gemini-api-key>
# AI_SERVICE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Production Deployment Notes
# -----------------------------------------------------------------------------
# 1. Change SPRING_PROFILES_ACTIVE to 'prod'
# 2. Set a strong JWT_SECRET (minimum 32 bytes)
# 3. Set a strong ERP_ENCRYPTION_KEY (minimum 32 bytes)
# 4. Configure production database credentials
# 5. Set ERP_CORS_ALLOWED_ORIGINS to your frontend domain(s)
# 6. Configure email credentials for notifications
# 7. Set up proper SSL termination via reverse proxy
# 8. Configure security notification recipients for alerts
