OPENAI_BASE_URL=http://127.0.0.1:8317/v1
OPENAI_API_KEY=dummy
OPENAI_MODEL=gpt-5.2(xhigh)

# Where the agent is allowed to read/write (defaults to repo root).
AGENT_WORKSPACE_ROOT=..

# Safety: keep shell execution off unless you explicitly enable it.
ALLOW_SHELL=0

# Runner behavior
POLL_INTERVAL_MS=2000
MAX_STEPS=50
